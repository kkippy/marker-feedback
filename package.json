{
  "name": "marker-feedback-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @marker/web",
    "build:web": "npm run build -w @marker/web",
    "build:extension": "npm run build -w @marker/extension",
    "build": "npm run build -ws --if-present",
    "test": "npm run test -ws --if-present"
  }
}
